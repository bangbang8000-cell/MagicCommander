{
  "name": "magiccommander",
  "version": "3.0.0",
  "description": "MagicCommander - 网络设备配置管理工具",
  "main": "dist-electron/main.js",
  "author": "Magic Commander Team",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "dev:electron": "electron .",
    "dev:all": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "tsc -p tsconfig.json && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:renderer && npm run build:electron",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder --win --mac --linux",
    "typecheck": "tsc --noEmit && tsc --noEmit -p electron/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ electron/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ electron/ --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"electron/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"electron/**/*.ts\""
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "clsx": "^2.1.0",
    "docx-preview": "^0.3.7",
    "electron-updater": "^6.8.9",
    "i18next": "^26.3.4",
    "i18next-fs-backend": "^2.6.6",
    "iconv-lite": "^0.7.2",
    "lucide-react": "^0.344.0",
    "mammoth": "^1.12.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "remark-gfm": "^4.0.1",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.35",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.1",
    "terser": "^5.48.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "vitest": "^1.6.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.magiccommander.app",
    "productName": "MagicCommander",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "bangbang8000-cell",
        "repo": "MagicCommander"
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend"
      },
      {
        "from": "workspace",
        "to": "workspace"
      },
      {
        "from": "example",
        "to": "example"
      },
      {
        "from": "resources/python",
        "to": "python"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icons/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MagicCommander"
    },
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icons/icon.icns",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icons/icon.png",
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}",
      "category": "Network",
      "maintainer": "Magic Commander Team"
    }
  },
  "allowScripts": {
    "electron@28.3.3": true,
    "esbuild@0.21.5": true
  }
}
